# AutoImport release automation.
#
#   fastlane mac test
#   fastlane mac build
#   fastlane mac release version:0.1.4

default_platform(:mac)

APP_NAME = "AutoImport"
BUNDLE_ID = "com.matcom.AutoImport"
TEAM_ID = "382G4857JD"
GITHUB_REPO = "mcomisso/autoimport"
SPARKLE_ACCOUNT = APP_NAME

platform :mac do
  desc "Run the unit tests"
  lane :test do
    generate_project
    run_tests(
      project: "#{APP_NAME}.xcodeproj",
      scheme: APP_NAME,
      destination: "platform=macOS"
    )
  end

  desc "Build a signed, notarized #{APP_NAME}.app into build/"
  lane :build do
    generate_project
    build_signed_app
    notarize_app
    UI.success("Notarized app at build/#{APP_NAME}.app")
  end

  desc "Ship a release: bump version, test, build, notarize, package DMG, appcast, tag, and publish"
  lane :release do |options|
    version = options[:version]
    UI.user_error!("Pass the new version, e.g. fastlane mac release version:0.1.4") unless version
    UI.user_error!("Version must look like x.y.z") unless version.match?(/\A\d+\.\d+(\.\d+)?\z/)

    ensure_git_status_clean
    bump_version(version)
    generate_project

    run_tests(
      project: "#{APP_NAME}.xcodeproj",
      scheme: APP_NAME,
      destination: "platform=macOS"
    )

    build_signed_app
    notarize_app
    dmg_path = create_dmg(version)
    update_appcast(version)

    git_add(path: ["project.yml", "appcast.xml"])
    git_commit(path: ["project.yml", "appcast.xml"], message: "Release #{version}")
    add_git_tag(tag: "v#{version}")
    push_to_git_remote(tags: true)

    sh("cd .. && gh release create 'v#{version}' '#{dmg_path}' " \
       "--repo #{GITHUB_REPO} --title '#{APP_NAME} #{version}' --generate-notes")
    UI.success("Released #{APP_NAME} #{version} -> https://github.com/#{GITHUB_REPO}/releases/tag/v#{version}")
  end

  def generate_project
    sh("cd .. && xcodegen generate")
  end

  def bump_version(version)
    current_build = sh("cd .. && grep -m1 'CURRENT_PROJECT_VERSION:' project.yml | awk '{print $2}'").strip.to_i
    sh("cd .. && sed -i '' 's/MARKETING_VERSION: .*/MARKETING_VERSION: #{version}/' project.yml")
    sh("cd .. && sed -i '' 's/CURRENT_PROJECT_VERSION: .*/CURRENT_PROJECT_VERSION: #{current_build + 1}/' project.yml")
  end

  def build_signed_app
    build_mac_app(
      project: "#{APP_NAME}.xcodeproj",
      scheme: APP_NAME,
      configuration: "Release",
      export_method: "developer-id",
      output_directory: "build",
      clean: true
    )
  end

  def notarize_app
    api_key = nil
    if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_PATH"]
      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: ENV["ASC_KEY_PATH"]
      )
    end

    unless api_key || ENV["NOTARIZE_APPLE_ID"]
      UI.user_error!("Configure notarization credentials. See fastlane/.env.example")
    end

    notarize(
      package: "build/#{APP_NAME}.app",
      bundle_id: BUNDLE_ID,
      api_key: api_key,
      username: api_key ? nil : ENV["NOTARIZE_APPLE_ID"],
      asc_provider: api_key ? nil : TEAM_ID,
      print_log: true
    )
  end

  def create_dmg(version)
    dmg = "build/#{APP_NAME}-#{version}.dmg"
    sh <<~SH
      cd ..
      rm -rf build/dmg "#{dmg}"
      mkdir -p build/dmg
      cp -R "build/#{APP_NAME}.app" build/dmg/
      ln -s /Applications build/dmg/Applications
      hdiutil create -volname "#{APP_NAME} #{version}" -srcfolder build/dmg -ov -format UDZO "#{dmg}"
      rm -rf build/dmg
    SH
    dmg
  end

  def update_appcast(version)
    tools = "build/SourcePackages/artifacts/sparkle/Sparkle/bin"
    sh("cd .. && [ -x #{tools}/generate_appcast ] || " \
       "xcodebuild -project #{APP_NAME}.xcodeproj -scheme #{APP_NAME} " \
       "-resolvePackageDependencies -clonedSourcePackagesDirPath build/SourcePackages")
    sh <<~SH
      cd ..
      rm -rf build/appcast && mkdir -p build/appcast
      cp "build/#{APP_NAME}-#{version}.dmg" build/appcast/
      #{tools}/generate_appcast --account #{SPARKLE_ACCOUNT} \
        --download-url-prefix "https://github.com/#{GITHUB_REPO}/releases/download/v#{version}/" \
        -o appcast.xml build/appcast
      rm -rf build/appcast
    SH
  end
end
